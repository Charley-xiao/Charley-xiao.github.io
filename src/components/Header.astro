---
const nav = [
  { href: '/', label: 'Home' },
  { href: '/research', label: 'Research' },
  { href: '/projects', label: 'Projects' },
  { href: '/publications', label: 'Publications' },
  { href: '/news', label: 'News' },
  { href: '/awards', label: 'Awards' },
  { href: '/about', label: 'About' },
  { href: '/cv', label: 'CV' },
  { href: '/blogs', label: 'Blogs' }
];
---

<header class="chrome-divider border-b">
  <div class="container-shell flex flex-col gap-4 py-5 md:flex-row md:items-center md:justify-between">
    <a href="/" class="text-main-ui text-lg font-semibold tracking-tight">Qiwen Xiao</a>
    <nav class="flex flex-wrap gap-x-5 gap-y-2 text-sm md:justify-end">
      {nav.map((item) => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>
  </div>
</header>
