---
import Tag from './Tag.astro';

const { href, item } = Astro.props;

const collectionLabels: Record<string, string> = {
  research: 'Research Record',
  projects: 'Project Submission',
  blogs: 'Forum Note'
};

const metaParts = [item.data.organization, item.data.role].filter(Boolean);
const metaText = metaParts.join(' / ');
const shouldShowThumbnail =
  (item.collection === 'research' || item.collection === 'projects') && Boolean(item.data.teaser);
---

<article class="card-surface rounded p-4">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <p class="page-kicker">{metaText || collectionLabels[item.collection] || item.collection}</p>
      <h3 class="record-row-title mt-1">
        <a href={href} class="link-accent">{item.data.title}</a>
      </h3>
      <p class="record-meta-line mt-1">{item.data.year}{item.data.dateRange ? ` / ${item.data.dateRange}` : ''}</p>
      <p class="record-row-summary">{item.data.summary}</p>
      <div class="mt-3 flex flex-wrap gap-2">
        {item.data.tags.map((tag: string) => <Tag label={tag} />)}
      </div>
    </div>

    <div class="flex shrink-0 items-start gap-3">
      {shouldShowThumbnail && (
        <a href={href} class="hidden overflow-hidden rounded border border-[color:var(--border)] bg-[color:var(--panel-subtle)] sm:block">
          <img
            src={item.data.teaser}
            alt={`${item.data.title} teaser`}
            class="h-20 w-28 object-cover"
            loading="lazy"
          />
        </a>
      )}

      <div class="shrink-0 text-right text-xs text-[color:var(--muted)]">
        <p>{item.data.year}</p>
      </div>
    </div>
  </div>
</article>
