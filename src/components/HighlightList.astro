---
import Tag from './Tag.astro';
import type { HighlightItem } from '../data/highlights';

interface Props {
  items: HighlightItem[];
  compact?: boolean;
  columns?: 1 | 2;
  showTags?: boolean;
}

const {
  items,
  compact = false,
  columns = 1,
  showTags = !compact
} = Astro.props;

const wrapperClass = columns === 2 ? 'grid gap-3 xl:grid-cols-2' : 'record-list';
const isExternalLink = (href: string) => href.startsWith('http') || href.endsWith('.pdf');
---

<div class={wrapperClass}>
  {items.map((item) => (
    <article class={`card-surface rounded ${compact ? 'p-4' : 'p-5'}`}>
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <p class="page-kicker">{item.subtitle}</p>
          <h3 class={`mt-1 font-semibold ${compact ? 'text-lg' : 'text-xl'} text-main-ui`}>{item.title}</h3>
        </div>
        <p class="shrink-0 text-xs text-[color:var(--muted)]">{item.date}</p>
      </div>

      <p class={`mt-2 ${compact ? 'text-sm leading-6' : 'text-sm leading-7'} text-soft-ui`}>{item.summary}</p>

      {showTags && item.tags && item.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {item.tags.map((tag) => <Tag label={tag} />)}
        </div>
      )}

      {item.links && item.links.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-3 text-sm">
          {item.links.map((link) => (
            <a
              href={link.href}
              class="link-accent"
              target={isExternalLink(link.href) ? '_blank' : undefined}
              rel={isExternalLink(link.href) ? 'noreferrer' : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      )}
    </article>
  ))}
</div>
