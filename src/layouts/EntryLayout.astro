---
import BaseLayout from './BaseLayout.astro';
import Tag from '../components/Tag.astro';

const { entry } = Astro.props;
const data = entry.data;
const hasActionUrl = (url?: string) => {
  const normalizedUrl = url?.trim();
  return Boolean(normalizedUrl && normalizedUrl !== '#');
};
const actionLinks = [
  { href: data.reportUrl, label: 'Report' },
  { href: data.repoUrl, label: 'Repository' },
  { href: data.paperUrl, label: 'Paper' },
  { href: data.demoUrl, label: 'Demo' },
  { href: data.posterUrl, label: 'Slides' }
].filter(({ href }) => hasActionUrl(href));
---

<BaseLayout title={`${data.title} | Qiwen Xiao`} description={data.summary}>
  <article class="mx-auto max-w-4xl">
    <div class="mb-8">
      <p class="text-muted-ui mb-2 text-sm">
        {data.organization ? `${data.organization} · ` : ''}{data.year}
      </p>
      <h1 class="text-4xl font-semibold tracking-tight">{data.title}</h1>
      <p class="text-soft-ui mt-4 text-lg">{data.summary}</p>

      <div class="mt-5 flex flex-wrap gap-2">
        {data.tags.map((tag: string) => <Tag label={tag} />)}
      </div>

      {actionLinks.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-3 text-sm">
          {actionLinks.map(({ href, label }) => (
            <a href={href} class="button-secondary rounded-xl px-4 py-2">
              {label}
            </a>
          ))}
        </div>
      )}
    </div>

    <div class="surface-frame mb-8 overflow-hidden rounded-3xl">
      <img src={data.teaser} alt={`${data.title} teaser`} class="h-auto w-full" />
    </div>

    <div class="prose-custom">
      <slot />
    </div>
  </article>
</BaseLayout>
