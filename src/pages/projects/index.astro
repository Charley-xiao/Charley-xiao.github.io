---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('projects')).sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout title="Projects | Qiwen Xiao" description="Projects by Qiwen Xiao">
  <section class="py-8">
    <h1 class="text-4xl font-semibold tracking-tight">Projects</h1>
    <p class="mt-4 max-w-3xl text-slate-300">
      Selected course, research, and engineering projects in various topics.
    </p>
  </section>

  <section class="grid gap-6 md:grid-cols-2">
    {items.map((item) => <Card href={`/projects/${item.id}/`} item={item} />)}
  </section>
</BaseLayout>