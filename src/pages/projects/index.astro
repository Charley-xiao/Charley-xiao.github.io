---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('projects')).sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout title="Projects | Qiwen Xiao" description="Project submissions by Qiwen Xiao">
  <div class="space-y-4">
    <section class="section-panel p-5">
      <p class="page-kicker">Index</p>
      <h1 class="page-title mt-2">Projects</h1>
      <p class="page-subtitle">
        Course work, engineering builds, and experimental systems with enough structure to deserve their own record.
      </p>
    </section>

    <section class="space-y-3">
      {items.map((item) => <Card href={`/projects/${item.id}/`} item={item} />)}
    </section>
  </div>
</BaseLayout>
