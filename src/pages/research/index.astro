---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('research')).sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout title="Research | Qiwen Xiao" description="Research experience of Qiwen Xiao">
  <section class="py-8">
    <h1 class="text-4xl font-semibold tracking-tight">Research</h1>
    <p class="mt-4 max-w-3xl text-slate-300">
      Research experience spanning various fields.
    </p>
  </section>

  <section class="grid gap-6 md:grid-cols-2">
    {items.map((item) => <Card href={`/research/${item.id}/`} item={item} />)}
  </section>
</BaseLayout>