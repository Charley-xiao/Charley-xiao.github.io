---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Qiwen Xiao" description="About Qiwen Xiao">
  <section class="mx-auto max-w-3xl py-10">
    <h1 class="text-4xl font-semibold tracking-tight">About</h1>
    <div class="prose-custom mt-8">
      <p>
        I am an undergraduate researcher interested in machine learning,
        computational imaging, and high-performance computing.
      </p>
      <p>
        My recent work has included lensless imaging with conditional flow matching,
        fused INT4 kernels for LLM inference, and layout generation with meta networks.
      </p>
      <p>
        I am currently affiliated with SUSTech and the UCI 3+2 Engineering Program.
      </p>
    </div>
  </section>
</BaseLayout>