---
import HighlightList from '../components/HighlightList.astro';
import { publicationItems } from '../data/highlights';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Publications | Qiwen Xiao" description="Papers, reports, and technical writing by Qiwen Xiao">
  <section class="py-8">
    <h1 class="text-4xl font-semibold tracking-tight">Publications</h1>
    <p class="text-soft-ui mt-4 max-w-3xl">
      Papers from recent work.
    </p>
  </section>

  <section>
    <HighlightList items={publicationItems} />
  </section>
</BaseLayout>
