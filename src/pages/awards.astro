---
import HighlightList from '../components/HighlightList.astro';
import { awardItems } from '../data/highlights';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Awards | Qiwen Xiao" description="Awards and recognitions earned by Qiwen Xiao">
  <div class="space-y-4">
    <section class="section-panel p-5">
      <p class="page-kicker">Index</p>
      <h1 class="page-title mt-2">Awards</h1>
      <p class="page-subtitle">
        A small ledger of competitions, distinctions, and course outcomes that managed to survive internal audit.
      </p>
    </section>

    <section>
      <HighlightList items={awardItems} />
    </section>
  </div>
</BaseLayout>
