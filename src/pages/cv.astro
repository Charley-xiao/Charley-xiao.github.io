---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV | Qiwen Xiao" description="Curriculum Vitae of Qiwen Xiao">
  <section class="py-10">
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <h1 class="text-4xl font-semibold tracking-tight">CV</h1>
      <a href="/cv/Qiwen_Xiao_CV.pdf" class="button-secondary rounded-2xl px-5 py-3">
        Download PDF
      </a>
    </div>

    <div class="surface-frame overflow-hidden rounded-3xl">
      <iframe
        src="/cv/Qiwen_Xiao_CV.pdf"
        class="h-[85vh] w-full"
        title="CV PDF"
      ></iframe>
    </div>
  </section>
</BaseLayout>
