---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="CV | Qiwen Xiao" description="Curriculum vitae of Qiwen Xiao">
  <div class="space-y-4">
    <section class="section-panel p-5">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div>
          <p class="page-kicker">Profile Document</p>
          <h1 class="page-title mt-2">Curriculum Vitae</h1>
          <p class="page-subtitle">A PDF version for everyone.</p>
        </div>
        <a href="/cv/Qiwen_Xiao_CV.pdf" class="button-secondary">Download PDF</a>
      </div>
    </section>

    <section class="section-panel overflow-hidden">
      <div class="panel-header">
        <span>Embedded Document</span>
      </div>
      <div class="panel-body p-0">
        <iframe src="/cv/Qiwen_Xiao_CV.pdf" class="h-[85vh] w-full" title="CV PDF"></iframe>
      </div>
    </section>
  </div>
</BaseLayout>
