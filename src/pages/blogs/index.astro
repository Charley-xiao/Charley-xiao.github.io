---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Card from '../../components/Card.astro';
import { getCollection } from 'astro:content';

const items = (await getCollection('blogs')).sort((a, b) => b.data.order - a.data.order);
---

<BaseLayout title="Notes | Qiwen Xiao" description="Paper notes, talk notes, and thoughts by Qiwen Xiao">
  <div class="space-y-4">
    <section class="section-panel p-5">
      <p class="page-kicker">Index</p>
      <h1 class="page-title mt-2">Notes</h1>
      <p class="page-subtitle">
        Paper notes, talk notes, experiments, and the occasional thought that was not supposed to become a full post.
      </p>
    </section>

    <section class="space-y-3">
      {items.map((item) => <Card href={`/blogs/${item.id}/`} item={item} />)}
    </section>
  </div>
</BaseLayout>
